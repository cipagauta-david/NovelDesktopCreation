{
  "name": "novel-desktop-creation",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ci": "playwright test --reporter=dot",
    "test": "npm run lint && npm run test:e2e:ci",
    "test:report": "playwright test --reporter=html && playwright show-report",
    "test:inspect": "playwright test --debug"
  },
